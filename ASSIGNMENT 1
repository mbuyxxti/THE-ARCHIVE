import tkinter as tk
from tkinter import messagebox, ttk
from collections import deque

# Data structures
students = []
deleted_stack = []
registration_queue = deque()

# Functions
def add_student():
    sid = entry_id.get().strip()
    name = entry_name.get().strip()
    program = entry_program.get().strip()
    year = entry_year.get().strip()

    if not sid or not name or not program or not year:
        messagebox.showwarning("Input Error", "All fields are required!")
        return

    # CHECK FOR UNIQUE ID
    for s in students:
        if s["id"] == sid:
            messagebox.showerror("Duplicate Error", "Student ID already exists!")
            return

    student = {"id": sid, "name": name, "program": program, "year": year}
    students.append(student)
    registration_queue.append(student)

    messagebox.showinfo("Success", "Student added successfully!")
    clear_entries()
    display_students()


def search_student():
    sid = entry_id.get().strip()
    for s in students:
        if s["id"] == sid:
            messagebox.showinfo(
                "Student Found",
                f"ID: {s['id']}\nName: {s['name']}\nProgram: {s['program']}\nYear: {s['year']}"
            )
            return
    messagebox.showwarning("Not Found", "Student not found.")


def update_student():
    sid = entry_id.get().strip()
    for s in students:
        if s["id"] == sid:
            s["name"] = entry_name.get().strip()
            s["program"] = entry_program.get().strip()
            s["year"] = entry_year.get().strip()

            messagebox.showinfo("Success", "Student updated successfully!")
            display_students()
            return
    messagebox.showwarning("Not Found", "Student not found.")


def delete_student():
    sid = entry_id.get().strip()
    for s in students:
        if s["id"] == sid:
            students.remove(s)
            deleted_stack.append(s)

            messagebox.showinfo("Deleted", "Student deleted.")
            display_students()
            return
    messagebox.showwarning("Not Found", "Student not found.")


def undo_delete():
    if deleted_stack:
        student = deleted_stack.pop()
        students.append(student)

        messagebox.showinfo("Undo", "Delete undone.")
        display_students()
    else:
        messagebox.showwarning("Empty", "No deleted records.")


def display_students():
    # Clear table
    for row in student_table.get_children():
        student_table.delete(row)

    # Insert updated records
    for s in students:
        student_table.insert("", tk.END, values=(s['id'], s['name'], s['program'], s['year']))

    # Update student count
    count_label.config(text=f"Total Students: {len(students)}")


def clear_entries():
    entry_id.delete(0, tk.END)
    entry_name.delete(0, tk.END)
    entry_program.delete(0, tk.END)
    entry_year.delete(0, tk.END)


# Function to show menu frame
def show_menu():
    menu_frame.pack(pady=20)
    menu_button.pack_forget()  # Hide menu button after click


# Tkinter GUI
root = tk.Tk()
root.title("Student Record System")
root.geometry("600x600")

# Title Frame
title_frame = tk.Frame(root, bg="lightblue", pady=10)
title_frame.pack(fill="x")

title_label = tk.Label(
    title_frame,
    text="STUDENT RECORD MANAGEMENT SYSTEM",
    font=("Arial", 18, "bold"),
    bg="black",
    fg="white"
)
title_label.pack()

# MENU button (start screen)
menu_button = tk.Button(
    root,
    text="MENU",
    font=("Arial", 16, "bold"),
    bg="green",
    fg="white",
    command=show_menu
)
menu_button.pack(pady=50)

# Hidden menu frame
menu_frame = tk.Frame(root)

# Entry Form
tk.Label(menu_frame, text="Student ID").grid(row=0, column=0, padx=5, pady=5)
entry_id = tk.Entry(menu_frame)
entry_id.grid(row=0, column=1, padx=5, pady=5)

tk.Label(menu_frame, text="Name").grid(row=1, column=0, padx=5, pady=5)
entry_name = tk.Entry(menu_frame)
entry_name.grid(row=1, column=1, padx=5, pady=5)

tk.Label(menu_frame, text="Program").grid(row=2, column=0, padx=5, pady=5)
entry_program = tk.Entry(menu_frame)
entry_program.grid(row=2, column=1, padx=5, pady=5)

tk.Label(menu_frame, text="Year").grid(row=3, column=0, padx=5, pady=5)
entry_year = tk.Entry(menu_frame)
entry_year.grid(row=3, column=1, padx=5, pady=5)

# Buttons
tk.Button(menu_frame, text="Add Student", command=add_student).grid(row=4, column=0, pady=5)
tk.Button(menu_frame, text="Search Student", command=search_student).grid(row=4, column=1, pady=5)
tk.Button(menu_frame, text="Update Student", command=update_student).grid(row=5, column=0, pady=5)
tk.Button(menu_frame, text="Delete Student", command=delete_student).grid(row=5, column=1, pady=5)
tk.Button(menu_frame, text="Undo Delete", command=undo_delete).grid(row=6, column=0, columnspan=2, pady=5)

# Table
student_table = ttk.Treeview(
    menu_frame,
    columns=("Student ID", "Name", "Program", "Year"),
    show="headings",
    height=8
)
student_table.grid(row=7, column=0, columnspan=2, pady=10)

for col in ("Student ID", "Name", "Program", "Year"):
    student_table.heading(col, text=col)
    student_table.column(col, width=120)

# Count label
count_label = tk.Label(menu_frame, text="Total Students: 0", font=("Arial", 12, "bold"))
count_label.grid(row=8, column=0, columnspan=2, pady=5)

root.mainloop()
