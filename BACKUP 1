def create_modern_button(parent, text, command, bg_color=ModernTheme.SECONDARY, 
                        width=15, relief="flat"):
    """Create a button with hover effects and modern styling"""
    btn = tk.Button(
        parent,
        text=text,
        command=command,
        bg=bg_color,
        fg=ModernTheme.LIGHT_TEXT,
        font=("Segoe UI", 10, "bold"),
        relief=relief,
        padx=10,
        pady=8,
        width=width,
        cursor="hand2",
        activebackground=ModernTheme.HOVER_SECONDARY if bg_color == ModernTheme.SECONDARY 
                         else ModernTheme.HOVER_ACCENT,
        activeforeground=ModernTheme.LIGHT_TEXT,
        bd=0
    )
    
    # Add hover effects
    def on_enter(event):
        btn.config(relief="raised")
    
    def on_leave(event):
        btn.config(relief="flat")
    
    btn.bind("<Enter>", on_enter)
    btn.bind("<Leave>", on_leave)
    
    return btn

def create_modern_entry(parent, placeholder=""):
    """Create an entry field with modern styling"""
    entry = tk.Entry(
        parent,
        font=("Segoe UI", 10),
        relief="flat",
        bd=0,
        bg="white",
        fg=ModernTheme.DARK_TEXT,
        insertbackground=ModernTheme.SECONDARY
    )
    
    # Add placeholder functionality
    if placeholder:
        entry.insert(0, placeholder)
        entry.config(fg=ModernTheme.BORDER)
        
        def on_focus_in(event):
            if entry.get() == placeholder:
                entry.delete(0, tk.END)
                entry.config(fg=ModernTheme.DARK_TEXT)
        
        def on_focus_out(event):
            if entry.get() == "":
                entry.insert(0, placeholder)
                entry.config(fg=ModernTheme.BORDER)
        
        entry.bind("<FocusIn>", on_focus_in)
        entry.bind("<FocusOut>", on_focus_out)
    
    return entry

def show_feedback(title: str, message: str, msg_type: str = "info"):
    """Display user-friendly feedback messages"""
    if msg_type == "success":
        messagebox.showinfo(title, f"✓ {message}")
    elif msg_type == "error":
        messagebox.showerror(title, f"✗ {message}")
    elif msg_type == "warning":
        messagebox.showwarning(title, f"⚠ {message}")
    else:
        messagebox.showinfo(title, message)

def get_timestamp_string():
    """Get current timestamp as formatted string"""
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")

