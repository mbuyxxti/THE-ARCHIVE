def add_student():
    """Add a new student with flexible validation and timestamping"""
    sid = entry_id.get().strip()
    name = entry_name.get().strip()
    program = entry_program.get().strip()
    year = entry_year.get().strip()

    # Flexible validation: Student ID is mandatory, others are optional
    if not sid:
        show_feedback(
            "Validation Error",
            "Student ID is required to create a record.",
            "error"
        )
        return

    # Check for unique ID
    for s in database.students:
        if s.id == sid:
            show_feedback(
                "Duplicate Record",
                f"A student with ID '{sid}' already exists. Please use a different ID.",
                "error"
            )
            return

    # Create new student record
    student = StudentRecord(
        id=sid,
        name=name,
        program=program,
        year=year
    )
    
    # Log the creation activity
    student.log_activity("Created", f"New record created with {sum([bool(name), bool(program), bool(year)])} fields")
    
    # Add to system
    database.students.append(student)
    database.registration_queue.append(student)
    database.add_operation_to_history("ADD", sid, f"Added: {name or 'N/A'}")
    
    # Provide friendly feedback
    show_feedback(
        "Record Created",
        f"Student ID '{sid}' has been successfully added to the system.",
        "success"
    )
    
    clear_entries()
    refresh_display()


def search_student():
    """Search for a student and display detailed information"""
    sid = entry_id.get().strip()
    
    if not sid:
        show_feedback("Search Error", "Please enter a Student ID to search.", "warning")
        return
    
    for s in database.students:
        if s.id == sid:
            # Build detailed information message
            details = f"""
Student ID: {s.id}
Name: {s.name or '(Not provided)'}
Program: {s.program or '(Not provided)'}
Year: {s.year or '(Not provided)'}

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Created: {s.created_at}
Updated: {s.updated_at or 'Never'}
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Activity History: {len(s.activity_history)} action(s)
            """
            show_feedback("Student Found", details.strip(), "info")
            return
    
    show_feedback(
        "Not Found",
        f"No student found with ID '{sid}'. Please check and try again.",
        "warning"
    )


def update_student():
    """Update student record with timestamp tracking"""
    sid = entry_id.get().strip()
    
    if not sid:
        show_feedback("Update Error", "Please enter a Student ID to update.", "warning")
        return
    
    for s in database.students:
        if s.id == sid:
            # Store original values for change tracking
            original = {
                "name": s.name,
                "program": s.program,
                "year": s.year
            }
            
            # Update with new values (allows partial updates)
            new_name = entry_name.get().strip()
            new_program = entry_program.get().strip()
            new_year = entry_year.get().strip()
            
            changes = []
            if new_name and new_name != original["name"]:
                s.name = new_name
                changes.append(f"Name: {original['name']} → {new_name}")
            if new_program and new_program != original["program"]:
                s.program = new_program
                changes.append(f"Program: {original['program']} → {new_program}")
            if new_year and new_year != original["year"]:
                s.year = new_year
                changes.append(f"Year: {original['year']} → {new_year}")
            
            if not changes:
                show_feedback(
                    "No Changes",
                    "No new information provided. Record remains unchanged.",
                    "warning"
                )
                return
            
            # Update timestamp and log activity
            s.updated_at = get_timestamp_string()
            change_summary = "; ".join(changes)
            s.log_activity("Updated", change_summary)
            database.add_operation_to_history("UPDATE", sid, change_summary)
            
            show_feedback(
                "Record Updated",
                f"Student ID '{sid}' has been successfully updated.\n\nChanges: {change_summary}",
                "success"
            )
            
            clear_entries()
            refresh_display()
            return
    
    show_feedback(
        "Not Found",
        f"No student found with ID '{sid}'. Cannot update non-existent record.",
        "error"
    )


def delete_student():
    """Delete student record with timestamp tracking"""
    sid = entry_id.get().strip()
    
    if not sid:
        show_feedback("Delete Error", "Please enter a Student ID to delete.", "warning")
        return
    
    for i, s in enumerate(database.students):
        if s.id == sid:
            # Log deletion time
            s.deleted_at = get_timestamp_string()
            s.log_activity("Deleted", f"Record deleted at {s.deleted_at}")
            
            # Move to deleted stack for undo capability
            deleted_student = database.students.pop(i)
            database.deleted_records.append(deleted_student)
            database.add_operation_to_history("DELETE", sid, f"Deleted: {s.name or 'N/A'}")
            
            show_feedback(
                "Record Deleted",
                f"Student ID '{sid}' has been removed. You can undo this action.",
                "success"
            )
            
            refresh_display()
            return
    
    show_feedback(
        "Not Found",
        f"No student found with ID '{sid}'. Cannot delete non-existent record.",
        "error"
    )


def undo_delete():
    """Restore a deleted student record"""
    if not database.deleted_records:
        show_feedback(
            "Nothing to Undo",
            "No deleted records available. All previous deletions have been restored.",
            "warning"
        )
        return
    
    student = database.deleted_records.pop()
    
    # Log restoration
    student.deleted_at = ""  # Clear deletion timestamp
    student.log_activity("Restored", f"Record restored from deletion at {get_timestamp_string()}")
    
    database.students.append(student)
    database.add_operation_to_history("RESTORE", student.id, f"Restored: {student.name or 'N/A'}")
    
    show_feedback(
        "Record Restored",
        f"Student ID '{student.id}' has been restored to the system.",
        "success"
    )
    
    refresh_display()


def view_activity_log():
    """Display the activity history of all operations"""
    if not database.operation_history:
        show_feedback(
            "Activity Log",
            "No operations have been recorded yet.",
            "info"
        )
        return
    
    # Build activity log message
    log_text = "═══════════════════════════════════════════\n"
    log_text += "SYSTEM ACTIVITY LOG\n"
    log_text += "═══════════════════════════════════════════\n\n"
    
    for entry in database.operation_history[-10:]:  # Show last 10 operations
        log_text += f"[{entry['timestamp']}] {entry['operation']}\n"
        log_text += f"  Student ID: {entry['student_id']}\n"
        log_text += f"  Details: {entry['details']}\n\n"
    
    show_feedback("Activity Log", log_text, "info")


