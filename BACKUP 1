def refresh_display():
    """Refresh the student table and statistics"""
    # Clear existing rows
    for row in student_table.get_children():
        student_table.delete(row)
    
    # Insert current records with timestamps
    for s in database.students:
        student_table.insert(
            "",
            tk.END,
            values=(
                s.id,
                s.name or "—",
                s.program or "—",
                s.year or "—",
                s.created_at
            ),
            tags=("data",)
        )
    
    # Update statistics
    total = len(database.students)
    complete = sum(1 for s in database.students if all([s.name, s.program, s.year]))
    incomplete = total - complete
    
    count_label.config(
        text=f"Total: {total}  |  Complete: {complete}  |  Incomplete: {incomplete}"
    )
    
    # Update deleted count
    deleted_count_label.config(text=f"Deleted (can undo): {len(database.deleted_records)}")


def clear_entries():
