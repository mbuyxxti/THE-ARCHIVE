# ============================================================================
# DATA STRUCTURES
# ============================================================================

@dataclass
class ActivityLog:
    """Tracks all operations performed on a record"""
    operation: str  # "Created", "Updated", "Deleted", "Restored"
    timestamp: str
    details: str

@dataclass
class StudentRecord:
    """Enhanced student record with timestamp tracking"""
    id: str
    name: str = ""
    program: str = ""
    year: str = ""
    created_at: str = ""
    updated_at: str = ""
    deleted_at: str = ""
    activity_history: List[ActivityLog] = None

    def __post_init__(self):
        if self.activity_history is None:
            self.activity_history = []
        if not self.created_at:
            self.created_at = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    def log_activity(self, operation: str, details: str = ""):
        """Record an activity in the history"""
        activity = ActivityLog(
            operation=operation,
            timestamp=datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            details=details
        )
        self.activity_history.append(activity)

    def to_dict(self):
        """Convert to dictionary, excluding activity_history for display"""
        return {
            "id": self.id,
            "name": self.name,
            "program": self.program,
            "year": self.year,
            "created_at": self.created_at,
            "updated_at": self.updated_at
        }

# ============================================================================
# GLOBAL STATE & DATA STRUCTURES
# ============================================================================

class StudentDatabase:
    """Central database manager with activity tracking"""
    def __init__(self):
        self.students: List[StudentRecord] = []
        self.deleted_records: deque = deque()  # For undo functionality
        self.registration_queue: deque = deque()
        self.operation_history: List[dict] = []

    def add_operation_to_history(self, operation: str, student_id: str, details: str = ""):
        """Log operation to global history"""
        self.operation_history.append({
            "operation": operation,
            "student_id": student_id,
            "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "details": details
        })

database = StudentDatabase()

